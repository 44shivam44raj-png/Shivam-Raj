/**
 * Note: The returned value should be long long.
 */
long long zeroFilledSubarray(int* nums, int numsSize) {
    long long count = 0;
    long long ans = 0;
    
    for (int i = 0; i < numsSize; i++) {
        if (nums[i] == 0) {
            count++;        // extend zero streak
            ans += count;   // add all new subarrays ending here
        } else {
            count = 0;      // reset streak
        }
    }
    
    return ans;
}
